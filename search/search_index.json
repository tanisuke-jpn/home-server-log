ocker/compose/#_7","title":"\u7ba1\u7406\u65b9\u91dd","text":"<p>\u5404\u30b5\u30fc\u30d3\u30b9\u3054\u3068\u306b\u30c7\u30a3\u30ec\u30af\u30c8\u30ea\u3092\u5206\u3051\u308b\u3002</p> <p>\u4f8b\uff1a</p> <pre><code>/opt/docker/\n\n\u251c jellyfin/\n\u251c navidrome/\n\u251c syncthing/\n\u2514 pihole/\n</code></pre>"},{"location":"03_docker/compose/#_8","title":"\u30e1\u30e2","text":"<p>\u8a2d\u5b9a\u30d5\u30a1\u30a4\u30eb\u306fGit\u7ba1\u7406\u5bfe\u8c61\u306b\u3059\u308b\u3002</p> <p>\u305f\u3060\u3057\u3001</p> <ul> <li>\u30d1\u30b9\u30ef\u30fc\u30c9</li> <li>API\u30ad\u30fc</li> <li>\u500b\u4eba\u60c5\u5831</li> </ul> <p>\u306f\u9664\u5916\u3059\u308b\u3002</p>"},{"location":"03_docker/docker/","title":"Docker","text":""},{"location":"03_docker/docker/#_1","title":"\u6982\u8981","text":"<p>Docker\u306f\u30a2\u30d7\u30ea\u30b1\u30fc\u30b7\u30e7\u30f3\u3092\u30b3\u30f3\u30c6\u30ca\u5358\u4f4d\u3067\u52d5\u4f5c\u3055\u305b\u308b\u4ed5\u7d44\u307f\u3002</p> <p>\u81ea\u5b85\u30b5\u30fc\u30d0\u3067\u306f\u3001\u5404\u30b5\u30fc\u30d3\u30b9\u3092\u5206\u96e2\u3057\u3066\u7ba1\u7406\u3059\u308b\u305f\u3081\u306b\u5229\u7528\u3059\u308b\u3002</p>"},{"location":"03_docker/docker/#_2","title":"\u5229\u7528\u76ee\u7684","text":"<p>\u3053\u306e\u30b5\u30fc\u30d0\u3067\u306f\u4ee5\u4e0b\u306e\u30b5\u30fc\u30d3\u30b9\u3092Docker\u4e0a\u3067\u52d5\u4f5c\u3055\u305b\u308b\u4e88\u5b9a\u3002</p> <ul> <li>Portainer</li> <li>Homarr</li> <li>Jellyfin</li> <li>Navidrome</li> <li>Syncthing</li> <li>Pi-hole</li> <li>EPGStation</li> </ul>"},{"location":"03_docker/docker/#_3","title":"\u30a4\u30f3\u30b9\u30c8\u30fc\u30eb","text":"<p>Ubuntu Server\u3078\u30a4\u30f3\u30b9\u30c8\u30fc\u30eb\uff1a</p> <pre><code>sudo apt update\n\nsudo apt install docker.io\n</code></pre>"},{"location":"03_docker/docker/#_4","title":"\u30b5\u30fc\u30d3\u30b9\u8d77\u52d5","text":"<p>Docker\u3092\u81ea\u52d5\u8d77\u52d5\uff1a</p> <pre><code>sudo systemctl enable docker\n</code></pre> <p>\u8d77\u52d5\uff1a</p> <pre><code>sudo systemctl start docker\n</code></pre>"},{"location":"03_docker/docker/#_5","title":"\u52d5\u4f5c\u78ba\u8a8d","text":"<p>\u30d0\u30fc\u30b8\u30e7\u30f3\u78ba\u8a8d\uff1a</p> <pre><code>docker --version\n</code></pre> <p>\u30b3\u30f3\u30c6\u30ca\u4e00\u89a7\uff1a</p> <pre><code>docker ps\n</code></pre>"},{"location":"03_docker/docker/#_6","title":"\u30e6\u30fc\u30b6\u30fc\u8a2d\u5b9a","text":"<p>sudo\u306a\u3057\u3067docker\u3092\u5229\u7528\u3059\u308b\u5834\u5408\uff1a</p> <pre><code>sudo usermod -aG docker $USER\n</code></pre> <p>\u8a2d\u5b9a\u53cd\u6620\u5f8c\u3001\u30ed\u30b0\u30a2\u30a6\u30c8\u30fb\u30ed\u30b0\u30a4\u30f3\u3059\u308b\u3002</p>"},{"location":"03_docker/docker/#_7","title":"\u7ba1\u7406\u65b9\u91dd","text":"<p>\u57fa\u672c\u7684\u306b\u4ee5\u4e0b\u306e\u69cb\u6210\u3067\u7ba1\u7406\u3059\u308b\u3002</p> <pre><code>Docker\n |\n \u251c \u30b3\u30f3\u30c6\u30ca\n |\n \u251c \u30dc\u30ea\u30e5\u30fc\u30e0\n |\n \u2514 compose\u30d5\u30a1\u30a4\u30eb\n</code></pre>"},{"location":"03_docker/docker/#_8","title":"\u6ce8\u610f","text":"<p>\u91cd\u8981\u306a\u30c7\u30fc\u30bf\u306f\u30b3\u30f3\u30c6\u30ca\u5185\u3067\u306f\u306a\u304f\u3001 \u30db\u30b9\u30c8\u5074\u30c7\u30a3\u30ec\u30af\u30c8\u30ea\u3078\u4fdd\u5b58\u3059\u308b\u3002</p> <p>\u4f8b\uff1a</p> <pre><code>/opt/docker/\n</code></pre>"},{"location":"03_docker/portainer/","title":"Portainer","text":""},{"location":"03_docker/portainer/#_1","title":"\u6982\u8981","text":"<p>Docker\u30b3\u30f3\u30c6\u30ca\u3092\u30d6\u30e9\u30a6\u30b6\u304b\u3089\u7ba1\u7406\u3059\u308bWeb UI\u3002</p>"},{"location":"03_docker/portainer/#_2","title":"\u76ee\u7684","text":"<p>\u30b3\u30de\u30f3\u30c9\u64cd\u4f5c\u3060\u3051\u3067\u306f\u78ba\u8a8d\u3057\u306b\u304f\u3044\u3001</p> <ul> <li>\u30b3\u30f3\u30c6\u30ca\u72b6\u614b</li> <li>\u30ed\u30b0</li> <li>\u30a4\u30e1\u30fc\u30b8</li> <li>\u30dc\u30ea\u30e5\u30fc\u30e0</li> </ul> <p>\u3092GUI\u3067\u7ba1\u7406\u3059\u308b\u3002</p>"},{"location":"03